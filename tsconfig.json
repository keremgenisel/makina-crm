{
  // Artımlı TypeScript benimseme. Vite/esbuild derlemeyi yapar; TS yalnızca TİP DENETİMİ
  // için (noEmit). checkJs KAPALI: her dosya kendi başında `// @ts-check` satırıyla
  // denetime dahil olur, böylece 70 dosyayı birden zorlamadan dosya dosya genişletilebilir.
  // Çekirdek veri şekilleri src/types.d.ts'te; en riskli saf mantık (utils.js, merge.js)
  // @ts-check ile denetleniyor. Denetim: `npm run typecheck`.
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
