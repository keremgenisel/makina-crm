{
  "name": "makina-crm",
  "productName": "Altunmak CRM",
  "version": "2.75.3",
  "description": "Altuntaş Makina müşteri ve servis takip sistemi",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "predev": "node scripts/ensure-native.cjs",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "build:win": "vite build && electron-builder --win",
    "preview": "vite preview",
    "release": "vite build && electron-builder --win --publish always",
    "postrelease": "electron-rebuild -f -w better-sqlite3",
    "bakim": "node scripts/bakim.cjs",
    "test": "vitest run",
    "lint": "eslint src electron scripts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "compression": "^1.8.1",
    "electron-updater": "^6.3.9",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.10",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "shell-quote": "1.8.4"
  },
  "build": {
    "appId": "com.altunmak.crm",
    "productName": "Altunmak CRM",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "npmRebuild": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "legalTrademarks": "Altuntaş Makina",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Altunmak CRM",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "perMachine": true,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "keremgenisel",
        "repo": "makina-crm",
        "releaseType": "release"
      }
    ],
    "icon": "build/icon.ico",
    "extraMetadata": {
      "author": "Altuntaş Makina Sanayi"
    }
  },
  "author": {
    "name": "Altuntaş Makina Sanayi",
    "email": "info@altunmak.com"
  },
  "homepage": "https://www.altunmak.com"
}
